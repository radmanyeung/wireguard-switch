<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WireguardSplitTunnel.MacApp.Views"
        x:Class="WireguardSplitTunnel.MacApp.Views.MainWindow"
        x:DataType="vm:MainWindowState"
        Title="WireGuard Split Tunnel"
        Width="720" Height="560"
        MinWidth="640" MinHeight="480">
  <Grid Margin="14" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="*">

    <!-- tunnel row -->
    <Border Grid.Row="0" Padding="10" CornerRadius="6" BorderThickness="1" BorderBrush="#33808080">
      <StackPanel Orientation="Vertical" Spacing="6">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Config:" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBlock Name="ConfigPathText" Text="(none)" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MinWidth="200"/>
          <Button Name="PickConfigButton" Content="Pick…" Click="OnPickConfigClick"/>
          <Button Name="EnableTunnelButton" Content="Enable Tunnel" Click="OnEnableTunnelClick"/>
          <Button Name="DisableTunnelButton" Content="Disable" Click="OnDisableTunnelClick"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Status:" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBlock Name="TunnelStatusText" Text="not connected" Foreground="#888"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- spacer -->
    <Rectangle Grid.Row="1" Height="10"/>

    <!-- domain input -->
    <Border Grid.Row="2" Padding="10" CornerRadius="6" BorderThickness="1" BorderBrush="#33808080">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBox Grid.Column="0" Name="NewDomainBox" Watermark="example.com" Margin="0,0,8,0"/>
        <Button Grid.Column="1" Content="Add Domain" Click="OnAddDomainClick" Margin="0,0,8,0"/>
        <Button Grid.Column="2" Content="Apply Routes" Click="OnApplyRoutesClick" Background="#306030" Foreground="White"/>
      </Grid>
    </Border>

    <!-- header -->
    <Grid Grid.Row="3" Margin="2,12,2,4" ColumnDefinitions="60,*,Auto,Auto">
      <TextBlock Grid.Column="0" Text="Enabled" FontWeight="SemiBold"/>
      <TextBlock Grid.Column="1" Text="Domain" FontWeight="SemiBold"/>
      <TextBlock Grid.Column="2" Text="Resolved IPs" FontWeight="SemiBold" Margin="0,0,12,0"/>
      <TextBlock Grid.Column="3" Text="" FontWeight="SemiBold"/>
    </Grid>

    <!-- list -->
    <Border Grid.Row="4" CornerRadius="6" BorderThickness="1" BorderBrush="#33808080">
      <ListBox Name="DomainList" Background="Transparent" SelectionMode="Single">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:DomainRuleRow">
            <Grid ColumnDefinitions="60,*,260,Auto" VerticalAlignment="Center">
              <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}"/>
              <TextBlock Grid.Column="1" Text="{Binding Domain}" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="2" Text="{Binding ResolvedSummary}" Foreground="#888" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
              <Button Grid.Column="3" Content="✕" Click="OnRemoveDomainClick" Tag="{Binding Domain}" Width="32" Padding="0"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <!-- log -->
    <Border Grid.Row="5" Margin="0,10,0,0" Padding="8" CornerRadius="4" Background="#15808080">
      <TextBlock Name="LogText" FontFamily="ui-monospace, Menlo, monospace" FontSize="11" Text="ready" TextWrapping="Wrap"/>
    </Border>
  </Grid>
</Window>
