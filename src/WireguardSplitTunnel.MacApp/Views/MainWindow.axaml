<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WireguardSplitTunnel.MacApp.Views"
        x:Class="WireguardSplitTunnel.MacApp.Views.MainWindow"
        x:DataType="vm:MainWindowState"
        Title="WireGuard Split Tunnel"
        Width="1120" Height="740"
        MinWidth="920" MinHeight="620">
  <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto" ColumnDefinitions="*">
    <TextBlock Grid.Row="0"
               Text="WireGuard Split Tunnel"
               FontSize="24"
               FontWeight="SemiBold" />

    <Border Grid.Row="1"
            Margin="0,12,0,12"
            Padding="10"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="#33808080">
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Text="Status:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <TextBlock Grid.Column="1" Name="TunnelStatusText" Text="not connected" Foreground="#888" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <TabControl Grid.Row="2" Name="MainTabs" SelectionChanged="OnMainTabsSelectionChanged">
      <TabItem Header="Tunnel">
        <Grid Margin="4,12,4,4" RowDefinitions="Auto,Auto,*">
          <Border Grid.Row="0" Padding="12" CornerRadius="8" BorderThickness="1" BorderBrush="#33808080">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
                <TextBlock Text="Config:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" Name="ConfigCombo" SelectionChanged="OnConfigSelectionChanged" MinWidth="320">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:TunnelConfigRow">
                      <StackPanel>
                        <TextBlock Text="{Binding Display}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ShortPath}" Foreground="#888" FontSize="11" TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2" Name="RefreshConfigsButton" Content="Refresh" Click="OnRefreshConfigsClick" MinWidth="90" Margin="8,0,0,0"/>
                <Button Grid.Column="3" Name="PickConfigButton" Content="Pick..." Click="OnPickConfigClick" MinWidth="90" Margin="8,0,0,0"/>
                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                        Name="StartAiVpnButton"
                        Content="Start AI VPN"
                        Click="OnStartAiVpnClick"
                        MinWidth="170"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Background="#0F766E"
                        Foreground="White"/>
              </Grid>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Name="EnableTunnelButton" Content="Enable Tunnel" Click="OnEnableTunnelClick" MinWidth="130"/>
                <Button Name="DisableTunnelButton" Content="Disable Tunnel" Click="OnDisableTunnelClick" MinWidth="130"/>
                <Button Content="Refresh Status" Click="OnRefreshStatusClick" MinWidth="120"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <TextBlock Grid.Row="1"
                     Margin="0,12,0,0"
                     Text="macOS uses wg-quick and will prompt for administrator approval when routes or tunnels are changed."
                     Foreground="#666"
                     TextWrapping="Wrap"/>
        </Grid>
      </TabItem>

      <TabItem Header="Domain Rules">
        <Grid Margin="4,12,4,4" RowDefinitions="Auto,Auto,*,Auto">
          <Border Grid.Row="0" Padding="12" CornerRadius="8" BorderThickness="1" BorderBrush="#33808080">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
              <TextBox Grid.Column="0" Name="NewDomainBox" Watermark="example.com or *.example.com"/>
              <Button Grid.Column="1" Content="Add Domain" Click="OnAddDomainClick" MinWidth="110"/>
              <ComboBox Grid.Column="2" Name="PresetCombo" SelectedIndex="3" MinWidth="150">
                <ComboBoxItem Content="OpenAI / ChatGPT"/>
                <ComboBoxItem Content="Claude"/>
                <ComboBoxItem Content="Google AI"/>
                <ComboBoxItem Content="AI Services Bundle"/>
              </ComboBox>
              <Button Grid.Column="3" Content="Add Preset" Click="OnAddPresetClick" MinWidth="110"/>
              <Button Grid.Column="4" Content="Apply Routes" Click="OnApplyRoutesClick" Background="#306030" Foreground="White" MinWidth="120"/>
            </Grid>
          </Border>

          <Grid Grid.Row="1" Margin="2,12,2,4" ColumnDefinitions="80,*,260,Auto">
            <TextBlock Grid.Column="0" Text="Enabled" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="1" Text="Domain" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="2" Text="Resolved IPs" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="3" Text="Action" FontWeight="SemiBold"/>
          </Grid>

          <Border Grid.Row="2" CornerRadius="8" BorderThickness="1" BorderBrush="#33808080">
            <ListBox Name="DomainList" Background="Transparent" SelectionMode="Single">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:DomainRuleRow">
                  <Grid ColumnDefinitions="80,*,260,Auto" VerticalAlignment="Center" Margin="4">
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                              Click="OnDomainEnabledChanged"
                              Tag="{Binding Domain}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Domain}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding ResolvedSummary}" Foreground="#888" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="3" Content="Remove" Click="OnRemoveDomainClick" Tag="{Binding Domain}" MinWidth="80"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>

          <StackPanel Grid.Row="3" Margin="0,12,0,0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Rollback" Click="OnRollbackClick" MinWidth="100"/>
            <Button Content="Restore Normal Routes" Click="OnRestoreNormalRoutesClick" MinWidth="170"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Software Rules">
        <Grid Margin="4,12,4,4" RowDefinitions="Auto,Auto,*,Auto">
          <Border Grid.Row="0" Padding="12" CornerRadius="8" BorderThickness="1" BorderBrush="#33808080">
            <StackPanel Spacing="10">
              <TextBlock Text="Phase 1 stores per-app bundle rules and WireGuard profile assignments. True routing is blocked until a signed Apple Network Extension entitlement is available."
                         TextWrapping="Wrap"
                         Foreground="#92400E"/>
              <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Text="Profile:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" Name="MacProfileCombo" MinWidth="220">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:MacTunnelProfileRow">
                      <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2" Content="Add WireGuard Profile" Click="OnAddMacProfileClick" MinWidth="160" Margin="8,0,0,0"/>
                <Button Grid.Column="3" Content="Pick App Bundle" Click="OnPickMacAppBundleClick" MinWidth="140" Margin="8,0,0,0"/>
              </Grid>
            </StackPanel>
          </Border>

          <Grid Grid.Row="1" Margin="0,12,0,12" ColumnDefinitions="*,*">
            <Border Grid.Column="0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="#33808080" Margin="0,0,6,0">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="WireGuard Profiles" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ListBox Grid.Row="1" Name="MacProfileList" Background="Transparent" MinHeight="130">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:MacTunnelProfileRow">
                      <Grid ColumnDefinitions="70,120,*,90,Auto" VerticalAlignment="Center" Margin="4">
                        <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" Click="OnMacProfileEnabledChanged" Tag="{Binding Id}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2" Text="{Binding ShortConfigPath}" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="3" Text="{Binding TunnelName}" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="4" Content="Remove" Click="OnRemoveMacProfileClick" Tag="{Binding Id}" MinWidth="80"/>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Border Grid.Column="1" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="#33808080" Margin="6,0,0,0">
              <StackPanel Spacing="8">
                <TextBlock Text="Apply Status" FontWeight="SemiBold"/>
                <TextBlock Name="MacSoftwareApplyStatusText"
                           Text="Not applied. Add profiles and app bundle rules first."
                           TextWrapping="Wrap"
                           Foreground="#92400E"/>
                <Button Content="Apply Mac Software Rules" Click="OnApplyMacSoftwareRulesClick" MinWidth="190" HorizontalAlignment="Left"/>
              </StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="70,160,*,150,220,Auto" Margin="2,0,2,4">
              <TextBlock Grid.Column="0" Text="Enabled" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="App" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="Bundle ID" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="3" Text="Profile" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="4" Text="Bundle Path" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="5" Text="Action" FontWeight="SemiBold"/>
            </Grid>
            <Border Grid.Row="1" CornerRadius="8" BorderThickness="1" BorderBrush="#33808080">
              <ListBox Name="MacSoftwareRuleList" Background="Transparent">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:MacSoftwareRuleRow">
                    <Grid ColumnDefinitions="70,160,*,150,220,Auto" VerticalAlignment="Center" Margin="4">
                      <CheckBox Grid.Column="0"
                                IsChecked="{Binding Enabled, Mode=TwoWay}"
                                Click="OnMacSoftwareRuleEnabledChanged"
                                Tag="{Binding}"/>
                      <TextBlock Grid.Column="1" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="2" Text="{Binding BundleIdentifier}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="3" Text="{Binding ProfileDisplayName}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="4" Text="{Binding ShortBundlePath}" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                      <Button Grid.Column="5"
                              Content="Remove"
                              Click="OnRemoveMacSoftwareRuleClick"
                              Tag="{Binding}"
                              MinWidth="80"/>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Grid>

          <TextBlock Grid.Row="3"
                     Margin="0,10,0,0"
                     Text="Bundle ID is the canonical app identity. The path is display/repair metadata only; WireGuard .conf private keys stay outside the package."
                     TextWrapping="Wrap"
                     Foreground="#666"/>
        </Grid>
      </TabItem>

      <TabItem Name="MonitorTabItem" Header="Monitor">
        <Grid Margin="4,12,4,4" RowDefinitions="Auto,Auto,*,Auto">
          <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
              <Button Name="StartMonitorButton" Content="Start Monitor" Click="OnStartMonitorClick" MinWidth="120"/>
              <Button Name="StopMonitorButton" Content="Stop Monitor" Click="OnStopMonitorClick" MinWidth="120" IsEnabled="False"/>
            </StackPanel>
            <TextBlock Name="MonitorStatusText" Text="Monitor: Stopped" FontWeight="SemiBold" VerticalAlignment="Center"/>
          </DockPanel>

          <Grid Grid.Row="1" Margin="0,12,0,12" ColumnDefinitions="*,*,320">
            <Border Grid.Column="0" Padding="12" CornerRadius="8" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="VPN / WireGuard" FontWeight="SemiBold" Foreground="#065F46"/>
                <TextBlock Name="VpnSpeedText" Text="Down 0 B/s | Up 0 B/s" Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Name="VpnTotalText" Text="Total: 0 B down / 0 B up" Margin="0,4,0,0" Foreground="#047857"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Padding="12" CornerRadius="8" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="Normal Network" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                <TextBlock Name="NormalSpeedText" Text="Down 0 B/s | Up 0 B/s" Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Name="NormalTotalText" Text="Total: 0 B down / 0 B up" Margin="0,4,0,0" Foreground="#2563EB"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="12" CornerRadius="8" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="Latency" FontWeight="SemiBold" Foreground="#9A3412"/>
                <TextBlock Name="VpnLatencyText" Text="VPN: Unavailable" Margin="0,8,0,0" FontWeight="SemiBold"/>
                <TextBlock Name="NormalLatencyText" Text="Normal: Unavailable" Margin="0,4,0,0" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="2" RowDefinitions="Auto,110,Auto,*">
            <TextBlock Name="GraphStatsText" Text="Mini graph: waiting for monitor samples" FontWeight="SemiBold"/>
            <Canvas Name="MonitorGraphCanvas" Grid.Row="1" Margin="0,8,0,12" ClipToBounds="True" Background="#FFFFFF">
              <Polyline Name="VpnGraphLine" Stroke="#10B981" StrokeThickness="2"/>
              <Polyline Name="NormalGraphLine" Stroke="#2563EB" StrokeThickness="2"/>
            </Canvas>
            <Grid Grid.Row="2" ColumnDefinitions="150,*,170,90,70,220,110" Margin="2,0,2,4">
              <TextBlock Grid.Column="0" Text="Process" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="Domain / IP" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="Remote" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="3" Text="Route" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="4" Text="Conns" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="5" Text="Path" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="6" Text="Last Seen" FontWeight="SemiBold"/>
            </Grid>
            <Border Grid.Row="3" CornerRadius="8" BorderThickness="1" BorderBrush="#33808080">
              <ListBox Name="MonitorActivityList" Background="Transparent">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:MonitorActivityRowView">
                    <Grid ColumnDefinitions="150,*,170,90,70,220,110" VerticalAlignment="Center" Margin="4">
                      <TextBlock Grid.Column="0" Text="{Binding ProcessName}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="1" Text="{Binding DomainOrAddress}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="2" Text="{Binding RemoteEndpoint}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="3" Text="{Binding Route}"/>
                      <TextBlock Grid.Column="4" Text="{Binding Connections}"/>
                      <TextBlock Grid.Column="5" Text="{Binding ShortPath}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="6" Text="{Binding LastSeen}"/>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Grid>

          <TextBlock Grid.Row="3" Name="MonitorWarningsText" Margin="0,10,0,0" Text="" TextWrapping="Wrap" Foreground="#92400E"/>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="3" Margin="0,10,0,0" Padding="8" CornerRadius="6" Background="#15808080">
      <TextBlock Name="LogText" FontFamily="ui-monospace, Menlo, monospace" FontSize="11" Text="ready" TextWrapping="Wrap"/>
    </Border>
  </Grid>
</Window>
