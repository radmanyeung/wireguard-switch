<Window x:Class="WireguardSplitTunnel.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Wireguard Split Tunnel"
        Height="760"
        Width="1180"
        MinHeight="620"
        MinWidth="940"
        Background="#F6F8FC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Wireguard Domain + Software Global Rules"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1F2937" />
            <TextBlock x:Name="VersionTextBlock"
                       Grid.Column="1"
                       Margin="16,6,0,0"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#46607A" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,14,0,10"
                Padding="12"
                CornerRadius="10"
                Background="#F3F7FF"
                BorderBrush="#C9D6FF"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="WireGuard Config" FontWeight="SemiBold" Foreground="#1F2937" />
                    <ComboBox x:Name="TunnelConfigCombo"
                              Margin="0,6,0,0"
                              MinWidth="420"
                              DisplayMemberPath="Display"
                              SelectedValuePath="Path" />
                    <CheckBox x:Name="AutoEnableCheckBox"
                              Margin="0,8,0,0"
                              Content="Auto enable selected tunnel when disconnected" />
                    <CheckBox x:Name="RestoreOnExitCheckBox"
                              Margin="0,6,0,0"
                              Content="Restore normal routing when app exits" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Global Mode (Domain + Software)" FontWeight="SemiBold" Foreground="#1F2937" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Mode:" VerticalAlignment="Center" Width="60" />
                        <ComboBox x:Name="UnifiedGlobalModeCombo" Width="220">
                            <ComboBoxItem Content="1 = Use WireGuard" />
                            <ComboBoxItem Content="2 = Bypass WireGuard" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2"
                        x:Name="RefreshConfigsButton"
                        Content="Refresh"
                        MinWidth="90"
                        Margin="12,0,8,0"
                        Padding="10,6"
                        VerticalAlignment="Top" />

                <Button Grid.Column="3"
                        x:Name="BrowseConfigButton"
                        Content="Browse..."
                        MinWidth="90"
                        Margin="0,0,8,0"
                        Padding="10,6"
                        VerticalAlignment="Top" />

                <StackPanel Grid.Column="4" Orientation="Vertical">
                    <Button x:Name="EnableTunnelButton"
                            Content="Enable Now"
                            MinWidth="110"
                            Padding="10,6"
                            Margin="0,0,0,8" />
                    <Button x:Name="SaveTempButton"
                            Content="Save Temp"
                            MinWidth="110"
                            Padding="10,6"
                            Margin="0,0,0,8" />
                    <Button x:Name="LoadTempButton"
                            Content="Load Temp"
                            MinWidth="110"
                            Padding="10,6" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,14"
                Padding="12"
                CornerRadius="10"
                Background="#E8F2FF"
                BorderBrush="#BCD8FF"
                BorderThickness="1">
            <TextBlock x:Name="TunnelStatusText"
                       Text="Tunnel: Unknown"
                       FontSize="14"
                       Foreground="#1E3A8A" />
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="3">
            <TabItem Header="Domain Rules">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DomainRulesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              RowHeaderWidth="0"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="*" />
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="90" />
                            <DataGridTextColumn Header="Resolved IPs" Binding="{Binding ResolvedIpCount}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1"
                                Margin="0,12,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="AddDomainRuleButton" Content="Add Domain" MinWidth="110" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="AddDomainPresetButton" Content="Add Preset" MinWidth="110" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="ToggleDomainEnabledButton" Content="Toggle Enabled" MinWidth="120" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="DeleteDomainRuleButton" Content="Delete Selected" MinWidth="130" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="ViewDomainIpsButton" Content="View IPs" MinWidth="100" Margin="0,0,8,0" Padding="10,6" />
                        
                        <Button x:Name="RollbackButton" Content="Rollback" MinWidth="100" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="SelfTestButton" Content="Self Test" MinWidth="100" Padding="10,6" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Software Rules">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="SoftwareRulesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              RowHeaderWidth="0"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="*" />
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="90" />
                            <DataGridCheckBoxColumn Header="Subprocess" Binding="{Binding IncludeSubprocesses}" Width="110" />
                            <DataGridTextColumn Header="Path" Binding="{Binding ShortPath}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1"
                                Margin="0,12,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="AddSoftwareRuleButton" Content="Add Software" MinWidth="120" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="PickRunningAppButton" Content="Pick Running App" MinWidth="140" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="ToggleSoftwareEnabledButton" Content="Toggle Enabled" MinWidth="120" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="ToggleSubprocessButton" Content="Toggle Subprocess" MinWidth="130" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="DeleteSoftwareRuleButton" Content="Delete Selected" MinWidth="130" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="ApplySoftwareButton" Content="Apply Software" MinWidth="130" Margin="0,0,8,0" Padding="10,6" />
                        <Button x:Name="SoftwareSelfTestButton" Content="Software Self Test" MinWidth="150" Padding="10,6" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem x:Name="MonitorTabItem" Header="Monitor">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="StartMonitorButton" Content="Start Monitor" MinWidth="120" Margin="0,0,8,0" Padding="10,6" />
                            <Button x:Name="StopMonitorButton" Content="Stop Monitor" MinWidth="120" Padding="10,6" IsEnabled="False" />
                        </StackPanel>
                        <TextBlock x:Name="MonitorStatusText"
                                   Text="Monitor: Stopped"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,12,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Margin="0,0,8,0"
                                Padding="12"
                                CornerRadius="10"
                                Background="#ECFDF5"
                                BorderBrush="#A7F3D0"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="VPN / WireGuard" FontWeight="SemiBold" Foreground="#065F46" />
                                <TextBlock x:Name="VpnSpeedText" Text="Down 0 B/s | Up 0 B/s" Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock x:Name="VpnTotalText" Text="Total: 0 B down / 0 B up" Margin="0,4,0,0" Foreground="#047857" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="12"
                                CornerRadius="10"
                                Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Normal Network" FontWeight="SemiBold" Foreground="#1D4ED8" />
                                <TextBlock x:Name="NormalSpeedText" Text="Down 0 B/s | Up 0 B/s" Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock x:Name="NormalTotalText" Text="Total: 0 B down / 0 B up" Margin="0,4,0,0" Foreground="#2563EB" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Margin="0,0,8,0"
                                Padding="12"
                                CornerRadius="10"
                                Background="#FFF7ED"
                                BorderBrush="#FED7AA"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Latency" FontWeight="SemiBold" Foreground="#9A3412" />
                                <TextBlock x:Name="VpnLatencyText" Text="VPN: Unavailable" Margin="0,8,0,0" FontWeight="SemiBold" />
                                <TextBlock x:Name="NormalLatencyText" Text="Normal: Unavailable" Margin="0,4,0,0" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="12"
                                CornerRadius="10"
                                Background="#F8FAFC"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="110" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="GraphStatsText"
                                           Text="Mini graph: waiting for monitor samples"
                                           FontWeight="SemiBold"
                                           Foreground="#334155" />
                                <Canvas x:Name="MonitorGraphCanvas"
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        ClipToBounds="True"
                                        Background="#FFFFFF">
                                    <Polyline x:Name="VpnGraphLine" Stroke="#10B981" StrokeThickness="2" />
                                    <Polyline x:Name="NormalGraphLine" Stroke="#2563EB" StrokeThickness="2" />
                                </Canvas>
                            </Grid>
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="3"
                              x:Name="MonitorActivityGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="150" />
                            <DataGridTextColumn Header="Domain / IP" Binding="{Binding DomainOrAddress}" Width="*" />
                            <DataGridTextColumn Header="Remote" Binding="{Binding RemoteEndpoint}" Width="170" />
                            <DataGridTextColumn Header="Route" Binding="{Binding Route}" Width="90" />
                            <DataGridTextColumn Header="Conns" Binding="{Binding Connections}" Width="70" />
                            <DataGridTextColumn Header="Path" Binding="{Binding ShortPath}" Width="220" />
                            <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="4"
                               x:Name="MonitorWarningsText"
                               Margin="0,10,0,0"
                               Text=""
                               TextWrapping="Wrap"
                               Foreground="#92400E" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
